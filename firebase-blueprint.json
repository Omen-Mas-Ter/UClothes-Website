{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role and profile info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Thrifted clothing item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "brand": { "type": "string" },
        "condition": { "type": "number", "description": "Rating out of 10" },
        "size": { "type": "string" },
        "price": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "brand", "condition", "size", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["cod", "stripe"] },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod"]
    },
    "Category": {
      "title": "Category",
      "description": "Product classification",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "slug"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory management"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order records"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    }
  }
}
